# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=

# HTTP server
APP_HOST=127.0.0.1
APP_PORT=8000

# Search
SEARCH_REGION=wt-wt
SEARCH_SAFESEARCH=moderate
SEARCH_MAX_RESULTS=6
SEARCH_BACKEND=html

# Response language (en, uk, de, fr, pl, ru)
SYSTEM_LANGUAGE=en

# LLM behaviour
LLM_TIMEOUT=60
LLM_RETRIES=1

# Pipeline features
ENABLE_FACTSHEET=true
ENABLE_QUERY_REWRITE=true
ENABLE_PAGE_FETCH=true
PAGE_FETCH_TOP_K=3
PAGE_FETCH_TIMEOUT=5

# History / cache
MAX_HISTORY_TURNS=6
CACHE_TTL=300
CACHE_SIZE=128
